    {
      "id": "n_build_sequence",
      "type": "text",
      "text": "# Build Sequence\n\n1. Directed lanes\n2. Cluster/hub metadata\n3. Triangle candidate scoring\n4. Delay event capture\n5. Lane reliability scorecards\n6. Return-trip recommendation workflow\n7. Pricing/risk guardrails\n8. Tableau/Power BI cockpit\n9. Field validation feedback loop\n\nRule: never automate what has not been manually validated for at least one route cycle.",
      "x": 1720,
      "y": 780,
      "width": 520,
      "height": 300
    }
